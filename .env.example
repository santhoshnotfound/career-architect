# Career Architect — Environment Variables
# Copy this file to .env and fill in your values.

# ── Optional: LLM skill extraction (falls back to keyword matcher if not set)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Optional: GitHub token (raises API limit from 60 → 5000 requests/hour)
# GITHUB_TOKEN=ghp_...

# ── Auth: JWT secret key (required for user accounts feature)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a hardcoded dev fallback is used — NOT safe for production.
# SECRET_KEY=your-random-64-hex-chars-here

# ── Auth: JWT token expiry in hours (default: 24)
# ACCESS_TOKEN_EXPIRE_HOURS=24
